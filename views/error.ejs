<%- include('partials/head', { title: 'Error' }) %>
<div class="message-page">
  <div class="message-card">
    <div class="message-card__icon" aria-hidden="true"
         style="background:var(--disagree-faint);color:var(--disagree)">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.5"
        stroke-linecap="round" stroke-linejoin="round">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
    </div>
    <h1 class="message-card__title">Something went wrong</h1>
    <p class="message-card__body"><%= message %></p>
    <a href="/" class="btn btn-ghost">Go home</a>
  </div>
</div>
<%- include('partials/foot') %>
