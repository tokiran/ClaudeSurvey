<%- include('../partials/head', { title: 'Survey results' }) %>
<div class="container">

  <header class="topbar">
    <h1>Results</h1>
    <div class="topbar-right">
      <a href="/admin" class="btn btn-ghost">← Dashboard</a>
      <% if (survey.status === 'open') { %>
        <form method="POST" action="/admin/survey/<%= survey.id %>/send" style="display:inline">
          <button class="btn">Send&thinsp;/&thinsp;resend emails</button>
        </form>
        <form method="POST" action="/admin/survey/<%= survey.id %>/close" style="display:inline"
              onsubmit="return confirm('Close this survey? Existing vote links will stop working.')">
          <button class="btn btn-danger">Close survey</button>
        </form>
      <% } %>
    </div>
  </header>

  <% if (flash) { %>
    <p class="alert alert-info" role="status"><%= flash %></p>
  <% } %>

  <div class="card" style="margin-bottom: var(--s-6)">
    <blockquote class="question-text"><%= survey.question %></blockquote>
    <span class="badge badge-<%= survey.status %>"><%= survey.status %></span>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-number"><%= stats.responded %>&thinsp;<span style="font-size:.5em;opacity:.5">/</span>&thinsp;<%= stats.total %></div>
      <div class="stat-label">Responded</div>
    </div>
    <div class="stat-card agree">
      <div class="stat-number"><%= stats.agree %></div>
      <div class="stat-label">Agree&ensp;<span style="opacity:.6">(<%= stats.agreePct %>%)</span></div>
    </div>
    <div class="stat-card disagree">
      <div class="stat-number"><%= stats.disagree %></div>
      <div class="stat-label">Disagree&ensp;<span style="opacity:.6">(<%= stats.disagreePct %>%)</span></div>
    </div>
  </div>

  <% if (stats.responded > 0) { %>
    <div class="bar-wrap" role="img"
         aria-label="<%= stats.agreePct %>% agree, <%= stats.disagreePct %>% disagree">
      <div class="bar-agree"    style="width:<%= stats.agreePct %>%"></div>
      <div class="bar-disagree" style="width:<%= stats.disagreePct %>%"></div>
    </div>
  <% } %>

  <table>
    <thead>
      <tr>
        <th scope="col">Participant</th>
        <th scope="col">Response</th>
        <th scope="col">Responded at</th>
      </tr>
    </thead>
    <tbody>
      <% for (const p of participants) { %>
        <tr>
          <td><%= p.email %></td>
          <td>
            <% if (!p.responded) { %>
              <span class="badge badge-closed">Pending</span>
            <% } else if (p.response === 'agree') { %>
              <span class="badge badge-agree">Agree</span>
            <% } else { %>
              <span class="badge badge-disagree">Disagree</span>
            <% } %>
          </td>
          <td class="muted small">
            <%= p.responded_at ? new Date(p.responded_at).toLocaleString() : '—' %>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>

</div>
<%- include('../partials/foot') %>
