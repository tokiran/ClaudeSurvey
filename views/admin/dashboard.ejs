<%- include('../partials/head', { title: 'Dashboard' }) %>
<div class="container">

  <header class="topbar">
    <a href="/admin" class="brand" aria-label="Pulse — Dashboard">
      <div class="brand__mark" aria-hidden="true">P</div>
      <span class="brand__name">Pulse</span>
    </a>
    <div class="topbar-right">
      <a href="/admin/new" class="btn">+ New survey</a>
      <form method="POST" action="/admin/logout" style="display:inline">
        <button class="btn btn-ghost">Sign out</button>
      </form>
    </div>
  </header>

  <% if (surveys.length === 0) { %>
    <div class="empty-state">
      <span class="empty-state__icon" aria-hidden="true">📋</span>
      <h2>No surveys yet</h2>
      <p>Create your first survey to start collecting opinions from your team.</p>
      <a href="/admin/new" class="btn">Create first survey</a>
    </div>
  <% } else { %>
    <ul class="survey-list" role="list">
      <% for (const s of surveys) { %>
        <li>
          <a href="/admin/survey/<%= s.id %>" class="survey-card">
            <div>
              <p class="survey-card__question">
                <%= s.question.length > 110 ? s.question.slice(0, 110) + '…' : s.question %>
              </p>
              <div class="survey-card__meta">
                <span class="badge badge-<%= s.status %>"><%= s.status %></span>
                <span class="meta-text"><%= s.responded || 0 %>&thinsp;/&thinsp;<%= s.total || 0 %> responded</span>
                <span class="meta-text"><%= new Date(s.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
              </div>
            </div>
            <span class="survey-card__chevron" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </span>
          </a>
        </li>
      <% } %>
    </ul>
  <% } %>

</div>
<%- include('../partials/foot') %>
