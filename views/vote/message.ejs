<%- include('../partials/head', { title }) %>
<%
  const okTitles = ['Response recorded', 'Already responded'];
  const isOk = okTitles.includes(title);
%>
<div class="message-page">
  <div class="message-card">
    <div class="message-card__icon" aria-hidden="true"
         style="<%= isOk ? 'background:var(--agree-faint);color:var(--agree)' : 'background:var(--bg-3);color:var(--text-3)' %>">
      <% if (isOk) { %>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      <% } else { %>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      <% } %>
    </div>
    <h1 class="message-card__title"><%= title %></h1>
    <p class="message-card__body"><%= message %></p>
  </div>
</div>
<%- include('../partials/foot') %>
