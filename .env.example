# Admin credentials
# Run `npm run hash-password` to generate the hash for your chosen password
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=$2b$10$examplehashgoeshere

# Session secret — use a long random string (e.g. `openssl rand -hex 32`)
SESSION_SECRET=change-me-to-a-long-random-string

# Base URL of this app, used to build vote links in emails (no trailing slash)
# For local dev: http://localhost:3000
# For Vercel: https://your-project.vercel.app
APP_BASE_URL=http://localhost:3000

# ── Database (Turso / libSQL) ──────────────────────────────────────────────
# Local dev — uses a local SQLite file, no Turso account needed:
TURSO_DATABASE_URL=file:./survey.db
TURSO_AUTH_TOKEN=

# Production — replace with your Turso database URL and auth token:
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ── Gmail SMTP (App Password) ──────────────────────────────────────────────
# Your full Gmail address
GMAIL_USER=you@gmail.com
# A 16-character App Password (NOT your normal Gmail password).
# Enable 2-Step Verification first, then:
#   Google Account → Security → App passwords → create one for "Mail"
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Port (local dev only — Vercel ignores this)
PORT=3000
